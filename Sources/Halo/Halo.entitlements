<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Hardened runtime denies AppleEvents to other apps by
        default. This entitlement opts in — the Now Playing
        publisher uses AppleScript against Spotify + Music to
        cover MediaRemote's macOS 14.4+ entitlement gate. macOS
        still prompts the user per-app on first send (TCC) so
        the user retains control over which apps Halo talks to.
    -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>
</dict>
</plist>
