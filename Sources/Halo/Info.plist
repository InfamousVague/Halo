<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key><string>Halo</string>
  <key>CFBundleDisplayName</key><string>Halo</string>
  <key>CFBundleIdentifier</key><string>com.mattssoftware.halo</string>
  <key>CFBundleExecutable</key><string>Halo</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleShortVersionString</key><string>0.1.3</string>
  <key>CFBundleVersion</key><string>0.1.3</string>
  <key>LSMinimumSystemVersion</key><string>14.0</string>
  <!--
    LSUIElement = true makes Halo an agent: no Dock icon, no
    main-menu, no Cmd-Tab presence. The island IS the UI.
  -->
  <key>LSUIElement</key><true/>
  <key>NSHighResolutionCapable</key><true/>
  <!--
    Bluetooth scanning permission — required for the AirPods
    battery publisher, which listens for Apple's proximity-
    pairing BLE advertisements (manufacturer 0x004C, subtype
    0x07). The advertisements carry left/right/case battery
    percentages; we only read them, never connect or pair.
  -->
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>Halo reads AirPods battery levels from nearby Bluetooth advertisements to show them in the island.</string>
</dict>
</plist>
