<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key><string>Halo</string>
  <key>CFBundleDisplayName</key><string>Halo</string>
  <key>CFBundleIdentifier</key><string>com.mattssoftware.halo</string>
  <key>CFBundleExecutable</key><string>Halo</string>
  <key>CFBundlePackageType</key><string>APPL</string>
  <key>CFBundleShortVersionString</key><string>1.0.25</string>
  <key>CFBundleVersion</key><string>1.0.25</string>
  <key>LSMinimumSystemVersion</key><string>14.0</string>
  <!--
    LSUIElement = true makes Halo an agent: no Dock icon, no
    main-menu, no Cmd-Tab presence. The island IS the UI.
  -->
  <key>LSUIElement</key><true/>
  <key>NSHighResolutionCapable</key><true/>
  <!--
    Bluetooth scanning permission — required for the AirPods
    battery publisher, which listens for Apple's proximity-
    pairing BLE advertisements (manufacturer 0x004C, subtype
    0x07). The advertisements carry left/right/case battery
    percentages; we only read them, never connect or pair.
  -->
  <key>NSBluetoothAlwaysUsageDescription</key>
  <string>Halo reads AirPods battery levels from nearby Bluetooth advertisements to show them in the island.</string>
  <!--
    Required so macOS knows to prompt the user (and show a
    rationale) the first time Halo asks Spotify / Music for
    track info. Without this string + the matching
    com.apple.security.automation.apple-events entitlement,
    AppleEvents are silently denied under the hardened
    runtime and the Now Playing card stays empty.
  -->
  <key>NSAppleEventsUsageDescription</key>
  <string>Halo asks Spotify and Music for the currently-playing track so the island can show it with album cover, scrubber, and playback controls. It also reads the active tab title from Safari, Chrome, Arc, Brave, and Edge for the browser-tab pill.</string>
  <!--
    Read-only EventKit access for the next-event countdown
    pill. Halo never writes events; the prompt fires the
    first time the Calendar publisher starts.
  -->
  <key>NSCalendarsUsageDescription</key>
  <string>Halo reads upcoming Calendar events to show a countdown to your next meeting in the island.</string>
</dict>
</plist>
